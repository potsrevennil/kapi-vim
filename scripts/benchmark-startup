#!/usr/bin/env bash

set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

RUNS="${1:-10}"
LOG="$(mktemp)"
trap 'rm -f "$LOG"' EXIT

echo "Benchmarking nvim startup time over ${RUNS} runs" >&2

times=()
for ((i = 1; i <= RUNS; i++)); do
  nvim --headless --startuptime "$LOG" +qa
  times+=("$(awk 'NF { last = $1 } END { print last }' "$LOG")")
done

printf '%s\n' "${times[@]}" | sort -n | awk '
  { a[NR] = $1; sum += $1 }
  END {
    min = a[1]
    max = a[NR]
    mean = sum / NR
    median = (NR % 2) ? a[(NR + 1) / 2] : (a[NR / 2] + a[NR / 2 + 1]) / 2
    printf "runs:   %d\n",     NR
    printf "min:    %.3f ms\n", min
    printf "median: %.3f ms\n", median
    printf "mean:   %.3f ms\n", mean
    printf "max:    %.3f ms\n", max
  }
'
